{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain-model/system.schema.json",
  "title": "Domain Model System",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "id", "title", "summary"],
  "properties": {
    "kind": {
      "const": "system"
    },
    "id": {
      "$ref": "shared.schema.json#/$defs/identifier"
    },
    "title": {
      "$ref": "shared.schema.json#/$defs/nonEmptyString"
    },
    "summary": {
      "$ref": "shared.schema.json#/$defs/summary"
    },
    "boundary": {
      "enum": ["internal", "external"]
    },
    "capabilities": {
      "$ref": "shared.schema.json#/$defs/stringArray"
    }
  }
}
