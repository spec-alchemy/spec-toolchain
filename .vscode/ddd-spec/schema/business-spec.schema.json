{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./business-spec.schema.json",
  "title": "Business Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "id", "title", "summary", "vocabulary", "domain"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "vocabulary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewerDetails"],
      "properties": {
        "viewerDetails": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/viewerDetailSemanticSpec"
          }
        }
      }
    },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["objects", "commands", "events", "aggregates", "processes"],
      "properties": {
        "objects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/objectSpec"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/commandSpec"
          }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/eventSpec"
          }
        },
        "aggregates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/aggregateSpec"
          }
        },
        "processes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/processSpec"
          }
        }
      }
    }
  },
  "$defs": {
    "viewerDetailSemanticSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "description"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fieldSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "required"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "payloadSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldSpec"
          }
        }
      }
    },
    "objectSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "title", "lifecycleField", "lifecycle", "fields"],
      "properties": {
        "kind": {
          "const": "object"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "lifecycleField": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fieldSpec"
          }
        }
      }
    },
    "commandSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "type", "target", "description", "payload"],
      "properties": {
        "kind": {
          "const": "command"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/payloadSpec"
        }
      }
    },
    "eventSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "type", "source", "description", "payload"],
      "properties": {
        "kind": {
          "const": "event"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "$ref": "#/$defs/payloadSpec"
        }
      }
    },
    "aggregateTransitionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "emit"],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "emit": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "payloadFrom"],
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "payloadFrom": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "pattern": "^\\$command\\.[A-Za-z_][A-Za-z0-9_]*$"
              }
            }
          }
        }
      }
    },
    "aggregateStateSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/aggregateTransitionSpec"
          }
        }
      }
    },
    "aggregateSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "objectId", "initial", "states"],
      "properties": {
        "kind": {
          "const": "aggregate"
        },
        "objectId": {
          "type": "string",
          "minLength": 1
        },
        "initial": {
          "type": "string",
          "minLength": 1
        },
        "states": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/aggregateStateSpec"
          }
        }
      }
    },
    "processStageSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "aggregate": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "advancesOn": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "final": {
          "type": "boolean"
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "processSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "title", "uses", "initialStage", "stages"],
      "properties": {
        "kind": {
          "const": "process"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "uses": {
          "type": "object",
          "additionalProperties": false,
          "required": ["aggregates"],
          "properties": {
            "aggregates": {
              "type": "object",
              "minProperties": 1,
              "propertyNames": {
                "pattern": "^[a-z][A-Za-z0-9]*$"
              },
              "additionalProperties": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "initialStage": {
          "type": "string",
          "minLength": 1
        },
        "stages": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/processStageSpec"
          }
        }
      }
    }
  }
}
