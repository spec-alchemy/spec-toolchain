{
  "name": "@spec-alchemy/ddd-spec",
  "version": "0.0.1",
  "description": "Zero-config DDD modeling CLI with validation, build generation, and a packaged viewer.",
  "author": "Spec Alchemy",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spec-alchemy/spec-toolchain.git",
    "directory": "packages/ddd-spec-cli"
  },
  "homepage": "https://github.com/spec-alchemy/spec-toolchain/tree/main/packages/ddd-spec-cli#readme",
  "bugs": {
    "url": "https://github.com/spec-alchemy/spec-toolchain/issues"
  },
  "keywords": [
    "ddd",
    "domain-driven-design",
    "design-as-code",
    "architecture",
    "yaml",
    "cli",
    "visualization"
  ],
  "type": "module",
  "bin": {
    "ddd-spec": "dist/ddd-spec-cli/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/ddd-spec-cli/index.d.ts",
      "default": "./dist/ddd-spec-cli/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "specToolchain": {
    "maturity": "beta"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "repo:cli": "node ./scripts/run-from-repo-root.mjs",
    "prepack": "npm run build",
    "test": "node ./scripts/test.mjs"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "cac": "^7.0.0",
    "jsonc-parser": "^3.3.1",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
