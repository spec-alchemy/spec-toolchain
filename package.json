{
  "name": "spec-alchemy-spec-toolchain",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "changeset": "changeset",
    "check:repo:validate": "node ./scripts/repo-cli.mjs validate viewer",
    "check:repo:build": "node ./scripts/repo-cli.mjs build viewer",
    "check:repo:goldens": "node ./scripts/repo-cli.mjs build goldens",
    "check:pkg:test": "npm run test --workspace=packages/ddd-spec-cli",
    "check:app:build": "npm run build --workspace=apps/ddd-spec-viewer",
    "check:release:status": "changeset status --verbose",
    "check:release:pack": "node ./scripts/release-pack-audit.mjs",
    "gate:pr": "npm run check:repo:build && npm run check:pkg:test && npm run check:app:build",
    "gate:release": "npm run gate:pr && npm run check:release:status && npm run check:release:pack",
    "ops:release:version": "changeset version",
    "ops:release:publish-dry-run": "node ./scripts/release-publish-dry-run.mjs",
    "ops:release:dry-run": "node ./scripts/release-dry-run.mjs",
    "ops:repo:viewer": "node ./scripts/repo-cli.mjs serve viewer --"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
